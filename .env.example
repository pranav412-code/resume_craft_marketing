# ── REQUIRED BEFORE DEPLOY ────────────────────────────────────────────────────
# Public origin of THIS marketing site. NO trailing slash.
# Drives metadataBase, canonicals, sitemap, robots, schema, llms.txt.
NEXT_PUBLIC_SITE_URL=https://resumecraft.site

# The product app (auth/builder/dashboard). NO trailing slash.
# Every CTA deep-links here: {APP_URL}/?src=marketing&page=...&role=...
# Until the app is deployed, point this at your local Vite dev server, e.g.
# NEXT_PUBLIC_APP_URL=http://localhost:5173
NEXT_PUBLIC_APP_URL=https://app.resumecraft.site

# FastAPI backend (already live on Render). Informational; not called by this site.
NEXT_PUBLIC_API_URL=https://resume-craft-backend-1r57.onrender.com

# Google Search Console HTML-tag verification (content="..." value). Optional —
# leave blank if you verify via DNS.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
